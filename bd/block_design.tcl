  # Create instance: counter_case_alterna_0, and set properties
  set block_name counter_case_alternate
  set block_cell_name counter_case_alterna_0
  if { [catch {set counter_case_alterna_0 [create_bd_cell -type module -reference $block_name $block_cell_name] } errmsg] } {
